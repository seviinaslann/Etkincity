@model IEnumerable<Etkincity.Models.Event>
@{
    ViewData["Title"] = "Admin Paneli";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary"><i class="fas fa-crown me-2"></i>Yönetici Paneli</h2>
        <a asp-action="Create" class="btn btn-success fw-bold px-4"><i class="fas fa-plus me-2"></i>Yeni Etkinlik Ekle</a>
    </div>

    <!-- İstatistik Kartları -->
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card bg-primary text-white border-0 shadow h-100 p-3" style="border-radius: 15px;">
                <div class="card-body text-center">
                    <i class="fas fa-calendar-alt fa-3x mb-3 opacity-50"></i>
                    <h3 class="fw-bold">@ViewBag.TotalEvents</h3>
                    <span class="fs-5">Toplam Etkinlik</span>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-success text-white border-0 shadow h-100 p-3" style="border-radius: 15px;">
                <div class="card-body text-center">
                    <i class="fas fa-ticket-alt fa-3x mb-3 opacity-50"></i>
                    <h3 class="fw-bold">@ViewBag.TotalReservations</h3>
                    <span class="fs-5">Satılan Bilet</span>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-warning text-dark border-0 shadow h-100 p-3" style="border-radius: 15px;">
                <div class="card-body text-center">
                    <i class="fas fa-wallet fa-3x mb-3 opacity-50"></i>
                    <h3 class="fw-bold">₺@ViewBag.TotalIncome.ToString("N2")</h3>
                    <span class="fs-5">Toplam Ciro</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Etkinlik Listesi -->
    <div class="card border-0 shadow-sm" style="border-radius: 15px;">
        <div class="card-header bg-white border-0 pt-4 pb-0 px-4">
            <h4 class="fw-bold">Tüm Etkinlikler</h4>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Etkinlik</th>
                            <th>Kategori</th>
                            <th>Tarih</th>
                            <th>Fiyat</th>
                            <th class="pe-4 text-end">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "https://images.unsplash.com/photo-1501281668745-f7f57925c3b4?auto=format&fit=crop&w=800&q=80" : item.ImageUrl)" onerror="this.onerror=null;this.src='https://images.unsplash.com/photo-1501281668745-f7f57925c3b4?auto=format&fit=crop&w=800&q=80';" class="rounded me-3" style="width: 50px; height: 50px; object-fit: cover;" alt="@item.Title" />
                                        <div class="fw-bold">@item.Title</div>
                                    </div>
                                </td>
                                <td><span class="badge bg-secondary">@item.Category</span></td>
                                <td>@item.Date.ToString("dd MMM yyyy HH:mm")</td>
                                <td class="fw-bold text-success">₺@item.Price.ToString("N0")</td>
                                <td class="pe-4 text-end">
                                    <div class="d-flex justify-content-end gap-2">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary"><i class="fas fa-edit"></i> Düzenle</a>
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Bu etkinliği silmek istediğinize emin misiniz?');">
                                            <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i> Sil</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                @if (!Model.Any())
                {
                    <div class="text-center p-5 text-muted">Sistemde henüz bir etkinlik bulunmuyor.</div>
                }
            </div>
        </div>
    </div>
</div>
