@model Etkincity.Models.Event
@using Etkincity.Models
@{
    ViewData["Title"] = "Yeni Etkinlik Ekle";
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-bold text-primary"><i class="fas fa-plus-circle me-2"></i>Yeni Etkinlik Ekle</h2>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-2"></i>Geri Dön</a>
            </div>

            <div class="card border-0 shadow-lg p-5" style="border-radius: 20px;">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    
                    <div class="row">
                        <div class="col-md-12 mb-3">
                            <label asp-for="Title" class="form-label fw-bold">Etkinlik Başlığı</label>
                            <input asp-for="Title" class="form-control" placeholder="Örn: Açık Hava Konseri">
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="Category" class="form-label fw-bold">Kategori</label>
                            <select asp-for="Category" class="form-select" asp-items="Html.GetEnumSelectList<EventCategory>()">
                                <option value="">Kategori Seçin...</option>
                            </select>
                            <span asp-validation-for="Category" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="Price" class="form-label fw-bold">Bilet Fiyatı (₺)</label>
                            <input asp-for="Price" type="number" step="0.01" class="form-control" placeholder="Örn: 150">
                            <span asp-validation-for="Price" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="Date" class="form-label fw-bold">Tarih ve Saat</label>
                            <input asp-for="Date" class="form-control">
                            <span asp-validation-for="Date" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="Location" class="form-label fw-bold">Mekan / Konum</label>
                            <input asp-for="Location" class="form-control" placeholder="Örn: Van Kalesi">
                            <span asp-validation-for="Location" class="text-danger small"></span>
                        </div>

                        <div class="col-md-12 mb-3">
                            <label asp-for="ImageUrl" class="form-label fw-bold">Kapak Görseli Linki (URL)</label>
                            <input asp-for="ImageUrl" class="form-control" placeholder="https://...">
                            <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                        </div>

                        <div class="col-md-12 mb-4">
                            <label asp-for="Description" class="form-label fw-bold">Etkinlik Detayları / Açıklama</label>
                            <textarea asp-for="Description" class="form-control" rows="4" placeholder="Etkinlik hakkında detaylı bilgi verin..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary btn-lg fw-bold"><i class="fas fa-save me-2"></i>Etkinliği Kaydet ve Yayınla</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
