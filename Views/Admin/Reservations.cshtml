@model IEnumerable<Etkincity.Models.Reservation>
@{
    ViewData["Title"] = "Satılan Biletler";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary"><i class="fas fa-ticket-alt me-2"></i>Satılan Biletler</h2>
        <a asp-action="Index" class="btn btn-outline-secondary fw-bold px-4"><i class="fas fa-arrow-left me-2"></i>Panele Dön</a>
    </div>

    <div class="card border-0 shadow-sm" style="border-radius: 15px;">
        <div class="card-header bg-white border-0 pt-4 pb-0 px-4">
            <h4 class="fw-bold">Tüm Satışlar</h4>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Bilet Kodu</th>
                            <th>Müşteri Adı</th>
                            <th>E-Posta</th>
                            <th>Etkinlik</th>
                            <th>Tarih</th>
                            <th class="text-end pe-4">Tutar</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-primary">@item.ReservationCode</td>
                                <td class="fw-bold">@item.CustomerName</td>
                                <td>@item.CustomerEmail</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="fw-bold">@item.Event?.Title</div>
                                    </div>
                                </td>
                                <td>@item.ReservationDate.ToString("dd MMM yyyy HH:mm")</td>
                                <td class="fw-bold text-success text-end pe-4">₺@item.TotalPrice.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
                @if (!Model.Any())
                {
                    <div class="text-center p-5 text-muted">Henüz satılmış bir bilet bulunmuyor.</div>
                }
            </div>
        </div>
    </div>
</div>
