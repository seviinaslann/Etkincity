@model IEnumerable<Etkincity.Models.Event>
@{
    ViewData["Title"] = "Ana Sayfa";
}

<div class="hero-section">
    <h1 class="hero-title">Van'ın Eğlence Merkezi</h1>
    <p class="hero-subtitle">En güncel konserler, tiyatrolar, festivaller ve spor müsabakaları için biletinizi hemen alın. Şehrin ritmini yakalayın!</p>
    <a href="#events" class="btn btn-primary btn-lg mt-3"><i class="fas fa-ticket-alt me-2"></i>Etkinlikleri Keşfet</a>
</div>

<div class="container mt-5" id="events">
    
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (ViewBag.RecommendedEvents != null && ((IEnumerable<Etkincity.Models.Event>)ViewBag.RecommendedEvents).Any())
    {
        <div class="mb-5 p-4 rounded-4" style="background: linear-gradient(135deg, rgba(46, 125, 50, 0.05) 0%, rgba(27, 94, 32, 0.1) 100%); border: 1px solid rgba(46, 125, 50, 0.2);">
            <h3 class="fw-bold mb-4" style="color: var(--accent-color);"><i class="fas fa-star me-2 text-warning"></i>Sizin İçin Önerilenler</h3>
            <div class="row g-4">
                @foreach (var item in (IEnumerable<Etkincity.Models.Event>)ViewBag.RecommendedEvents)
                {
                    <div class="col-md-4">
                        <div class="card event-card h-100" style="border-color: rgba(46, 125, 50, 0.4);">
                            <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "https://images.unsplash.com/photo-1501281668745-f7f57925c3b4?auto=format&fit=crop&w=800&q=80" : item.ImageUrl)" onerror="this.onerror=null;this.src='https://images.unsplash.com/photo-1501281668745-f7f57925c3b4?auto=format&fit=crop&w=800&q=80';" class="card-img-top" alt="@item.Title">
                            <div class="card-body d-flex flex-column">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <span class="badge bg-success mb-2">@item.Category</span>
                                    <span class="price-tag">@(item.Price == 0 ? "Ücretsiz" : $"₺{item.Price}")</span>
                                </div>
                                <h5 class="card-title">@item.Title</h5>
                                <p class="card-text mb-3"><i class="fas fa-map-marker-alt text-danger me-2"></i>@item.Location</p>
                                <p class="card-text mb-4"><i class="far fa-calendar-alt text-warning me-2"></i>@item.Date.ToString("dd MMMM yyyy - HH:mm")</p>
                                <div class="mt-auto">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-success w-100 fw-bold"><i class="fas fa-ticket-alt me-2"></i>Hemen İncele</a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">Yaklaşan Etkinlikler</h2>
        
        <form asp-action="Index" method="get" class="d-flex" style="max-width: 350px; width: 100%;">
            <div class="input-group shadow-sm rounded-pill overflow-hidden">
                <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control border-0 px-4" placeholder="Etkinlik veya mekan ara...">
                <button type="submit" class="btn btn-primary px-4"><i class="fas fa-search"></i></button>
            </div>
        </form>
    </div>

    <div class="row g-4">
        @if (!Model.Any())
        {
            <div class="col-12 text-center py-5">
                <i class="fas fa-search fa-3x mb-3 text-secondary"></i>
                <h4 class="text-secondary">Aradığınız kriterlere uygun etkinlik bulunamadı.</h4>
                <a asp-action="Index" class="btn btn-outline-primary mt-3 rounded-pill">Tüm Etkinlikleri Gör</a>
            </div>
        }
        else
        {
            @foreach (var item in Model)
            {
                <div class="col-md-4">
                    <div class="card event-card h-100">
                        <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "https://images.unsplash.com/photo-1501281668745-f7f57925c3b4?auto=format&fit=crop&w=800&q=80" : item.ImageUrl)" onerror="this.onerror=null;this.src='https://images.unsplash.com/photo-1501281668745-f7f57925c3b4?auto=format&fit=crop&w=800&q=80';" class="card-img-top" alt="@item.Title">
                        <div class="card-body d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                @{
                                    string badgeClass = item.Category switch {
                                        Etkincity.Models.EventCategory.Konser => "bg-primary",
                                        Etkincity.Models.EventCategory.Spor => "bg-warning text-dark",
                                        Etkincity.Models.EventCategory.Tiyatro => "bg-success",
                                        Etkincity.Models.EventCategory.Festival => "bg-danger",
                                        Etkincity.Models.EventCategory.Sergi => "bg-info",
                                        _ => "bg-secondary"
                                    };
                                }
                                <span class="badge @badgeClass mb-2">@item.Category</span>
                                <span class="price-tag">@(item.Price == 0 ? "Ücretsiz" : $"₺{item.Price}")</span>
                            </div>
                            <h5 class="card-title">@item.Title</h5>
                            <p class="card-text mb-3"><i class="fas fa-map-marker-alt text-danger me-2"></i>@item.Location</p>
                            <p class="card-text mb-4"><i class="far fa-calendar-alt text-warning me-2"></i>@item.Date.ToString("dd MMMM yyyy - HH:mm")</p>
                            <div class="mt-auto">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-primary w-100"><i class="fas fa-ticket-alt me-2"></i>Bilet Al / İncele</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>