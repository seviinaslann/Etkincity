@model Etkincity.Controllers.LoginViewModel
@{
    ViewData["Title"] = "Giriş Yap";
}

<div class="container mt-5 pt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card event-card border-0 shadow-lg p-5">
                <div class="text-center mb-4">
                    <h2 class="fw-bold text-primary mb-2">Hoş Geldin</h2>
                    <p class="text-secondary">Biletlerini yönetmek için giriş yap.</p>
                </div>

                <form asp-action="Login" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-bold">E-Posta Adresi</label>
                        <div class="input-group">
                            <span class="input-group-text bg-transparent"><i class="fas fa-envelope text-secondary"></i></span>
                            <input asp-for="Email" class="form-control bg-transparent" placeholder="ornek@mail.com">
                        </div>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Password" class="form-label fw-bold">Şifre</label>
                        <div class="input-group">
                            <span class="input-group-text bg-transparent"><i class="fas fa-lock text-secondary"></i></span>
                            <input asp-for="Password" class="form-control bg-transparent" placeholder="Şifrenizi girin">
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div class="form-check">
                            <input asp-for="RememberMe" class="form-check-input">
                            <label asp-for="RememberMe" class="form-check-label text-secondary">Beni Hatırla</label>
                        </div>
                        <a href="#" class="text-primary text-decoration-none small fw-bold">Şifremi Unuttum</a>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary btn-lg">Giriş Yap</button>
                    </div>
                </form>

                <div class="text-center mt-4">
                    <p class="text-secondary">Henüz hesabın yok mu? <a asp-action="Register" class="fw-bold text-primary text-decoration-none">Kayıt Ol</a></p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
