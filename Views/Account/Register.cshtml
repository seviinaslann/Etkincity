@model Etkincity.Controllers.RegisterViewModel
@{
    ViewData["Title"] = "Kayıt Ol";
}

<div class="container mt-5 pt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card event-card border-0 shadow-lg p-5">
                <div class="text-center mb-4">
                    <h2 class="fw-bold text-primary mb-2">Aramıza Katıl</h2>
                    <p class="text-secondary">Etkincity'nin ayrıcalıklı dünyasına hoş geldin.</p>
                </div>

                <form asp-action="Register" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label fw-bold">Ad Soyad</label>
                        <div class="input-group">
                            <span class="input-group-text bg-transparent"><i class="fas fa-user text-secondary"></i></span>
                            <input asp-for="FullName" class="form-control bg-transparent" placeholder="Örn: Ahmet Yılmaz">
                        </div>
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-bold">E-Posta Adresi</label>
                        <div class="input-group">
                            <span class="input-group-text bg-transparent"><i class="fas fa-envelope text-secondary"></i></span>
                            <input asp-for="Email" class="form-control bg-transparent" placeholder="ornek@mail.com">
                        </div>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label fw-bold">Şifre</label>
                        <div class="input-group">
                            <span class="input-group-text bg-transparent"><i class="fas fa-lock text-secondary"></i></span>
                            <input asp-for="Password" class="form-control bg-transparent" placeholder="En az 6 karakter">
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="form-label fw-bold">Şifre (Tekrar)</label>
                        <div class="input-group">
                            <span class="input-group-text bg-transparent"><i class="fas fa-check-circle text-secondary"></i></span>
                            <input asp-for="ConfirmPassword" class="form-control bg-transparent" placeholder="Şifrenizi doğrulayın">
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary btn-lg">Ücretsiz Kayıt Ol</button>
                    </div>
                </form>

                <div class="text-center mt-4">
                    <p class="text-secondary">Zaten bir hesabın var mı? <a asp-action="Login" class="fw-bold text-primary text-decoration-none">Giriş Yap</a></p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
